---
interface Props {
  src: string;
  width: number;
  height: number;
  alt: string;
  caption: string;
  date: string;
  dateLabel: string;
}

const { src, width, height, alt, caption, date, dateLabel } = Astro.props;
---

<article
  class="polaroid-card rounded-sm bg-white p-3 pb-6 shadow-xl ring-1 ring-black/5"
>
  <div class="overflow-hidden rounded-sm bg-base">
    <img
      src={src}
      width={width}
      height={height}
      alt={alt}
      class="aspect-[4/3] w-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>
  <p class="mt-3 font-serif text-[1.25rem] leading-snug text-primary">{caption}</p>
  <time
    datetime={date}
    class="mt-1 block text-[0.75rem] uppercase tracking-widest text-accent">{dateLabel}</time>
</article>

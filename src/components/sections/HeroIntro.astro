---
---

<section
  class="hero-intro flex min-h-[100svh] flex-col items-center justify-center px-6 py-24 text-center relative"
  aria-label="Вступление"
>
  <h1 class="hero-intro__title font-serif text-[2.5rem] md:text-[3.5rem] leading-none text-primary mb-8 tracking-tight drop-shadow-sm">
    Коля <span class="text-accent italic font-light text-[3rem] md:text-[4rem]">&</span> Маша
  </h1>

  <div class="hero-intro__sub-title mt-6 flex items-center gap-4">
    <span class="h-px w-8 bg-accent/40 rounded-full"></span>
    <h2 class="font-serif text-[1.4rem] md:text-[1.6rem] italic text-primary/80 drop-shadow-sm">
      Это наша маленькая история любви 🤍
    </h2>
    <span class="h-px w-8 bg-accent/40 rounded-full"></span>
  </div>

  <div class="hero-intro__sub mt-12 flex flex-col items-center gap-4 w-full max-w-sm">
    <div class="rounded-3xl border border-accent/30 bg-white/50 p-6 shadow-lg backdrop-blur-md">
      <p class="text-[1.1rem] leading-relaxed text-primary/90 font-serif">
        <span class="text-accent font-semibold">Включи звук</span>, никуда не торопись и просто
        <span class="font-bold">листай вниз</span> до самого конца.
      </p>
    </div>
  </div>

  <div
    class="hero-intro__cue absolute bottom-12 flex flex-col items-center gap-3 text-[0.75rem] uppercase tracking-widest text-primary/60"
    aria-hidden="true"
  >
    <span>Листай вниз</span>
    <div class="flex h-11 w-7 justify-center rounded-full border-2 border-primary/20 pt-2">
      <div class="hero-intro__wheel h-2.5 w-1 rounded-full bg-accent"></div>
    </div>
  </div>
</section>

<style>
  /* Вернул класс для анимации заголовка с именами */
  .hero-intro__title,
  .hero-intro__sub-title,
  .hero-intro__sub,
  .hero-intro__cue {
    opacity: 0;
    animation: hero-fade 1.5s ease-out forwards;
  }

  /* Настраиваем лесенку задержек */
  .hero-intro__title {
    animation-delay: 0.2s; /* Имена появляются почти сразу */
  }

  .hero-intro__sub-title {
    animation-delay: 1s; /* "Наша история" всплывает чуть позже */
  }

  .hero-intro__sub {
    animation-delay: 1.8s; /* Плашка с правилами */
  }

  .hero-intro__cue {
    animation-delay: 2.8s; /* Колесико скролла */
  }

  .hero-intro__wheel {
    animation: scroll-wheel 2s ease-in-out infinite;
  }

  @keyframes hero-fade {
    from {
      opacity: 0;
      transform: translate3d(0, 16px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  @keyframes scroll-wheel {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    50% {
      transform: translateY(12px);
      opacity: 0;
    }
    100% {
      transform: translateY(0);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-intro__title,
    .hero-intro__sub-title,
    .hero-intro__sub,
    .hero-intro__cue {
      animation: none;
      opacity: 1;
      transform: none;
    }

    .hero-intro__wheel {
      animation: none;
    }
  }
</style>

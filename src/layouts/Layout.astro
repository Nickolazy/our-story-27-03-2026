---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Наша история' } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}/favicon-light.ico`}
      media="(prefers-color-scheme: dark)"
    />

    <link
      rel="icon"
      href={`${import.meta.env.BASE_URL}/favicon-dark.ico`}
      media="(prefers-color-scheme: light)"
    />

    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Playfair+Display:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
  </body>
</html>
